{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "vitest.config.*",
    "playwright.config.*",
    "src/core/**/*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/common/**/*",
    "e2e/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@common/*": ["src/common/*"]
    }
  }
}
